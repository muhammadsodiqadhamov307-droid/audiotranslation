GEMINI_API_KEY=your_gemini_api_key_here

# Optional, only needed for gated Hugging Face models such as Sayro.
# Create at https://huggingface.co/settings/tokens after accepting the Sayro model terms.
HF_TOKEN=your_huggingface_token_here

# Optional model fallback order for transcription + translation.
GEMINI_TRANSCRIBE_MODELS=gemini-2.0-flash,gemini-2.5-flash,gemini-2.5-flash-lite,gemini-2.0-flash-lite

# Optional Kokoro voice overrides for English and Russian.
KOKORO_EN_LANG=a
KOKORO_EN_VOICE=af_heart
KOKORO_RU_LANG=r
KOKORO_RU_VOICE=rf_voice

# Uzbek TTS mode:
# mms   = fastest and safest on older PCs
# auto  = Sayro first, then MMS fallback
# sayro = Sayro only
UZBEK_TTS_MODE=mms

# Optional Uzbek TTS model overrides.
SAYRO_MODEL=uzlm/sayro-tts-1.7B
SAYRO_DEVICE=cpu
MMS_UZ_MODEL=facebook/mms-tts-uzb-script_cyrillic
